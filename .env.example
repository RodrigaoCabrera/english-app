# Database
DATABASE_URL=postgresql://english_user:english_pass@localhost:5432/english_app

# DeepSeek — used for reading generation and word definitions
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# DeepSeek daily token budget (optional, defaults shown below)
DEEPSEEK_DAILY_INPUT_LIMIT=50000
DEEPSEEK_DAILY_OUTPUT_LIMIT=10000

# OpenAI — used for TTS audio (tts-1 model)
OPENAI_API_KEY=sk-...

# Unsplash — used for word illustrations
# Get your Access Key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=...

# Azure Cognitive Services — used for Pronunciation Assessment
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
