# ─── Database (required) ───────────────────────────────────────────────
DATABASE_URL=postgresql://english_user:english_pass@localhost:5432/english_app

# ─── Ollama — reading passage generation ───────────────────────────────
# If OLLAMA_API_KEY is set, the app connects to Ollama Cloud (https://ollama.com).
# Otherwise it falls back to a local Ollama at OLLAMA_HOST.
OLLAMA_API_KEY=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Daily token budget for Ollama calls (optional, defaults shown)
DEEPSEEK_DAILY_INPUT_LIMIT=50000
DEEPSEEK_DAILY_OUTPUT_LIMIT=10000

# ─── OpenAI — word pronunciation audio (TTS, required for /audio) ───────
OPENAI_API_KEY=sk-...

# ─── Unsplash — word illustrations (optional, degrades to no image) ─────
# Get an Access Key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ─── Azure Cognitive Services — pronunciation assessment (required) ─────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ─── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Clerk — authentication (required) ─────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Optional code-enforced allowlist fallback (comma-separated emails)
ALLOWLIST_EMAILS=
